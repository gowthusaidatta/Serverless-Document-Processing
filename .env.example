# LocalStack Configuration
LOCALSTACK_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_INCOMING_TOPIC=claims.incoming
KAFKA_PROCESSED_TOPIC=claims.processed
KAFKA_CONSUMER_GROUP=claims-processor-group

# Step Functions Configuration
STEP_FUNCTION_STATE_MACHINE_NAME=ClaimProcessor
STEP_FUNCTION_ROLE_ARN=arn:aws:iam::000000000000:role/stepfunctions-role
STEP_FUNCTION_ENDPOINT_URL=http://localhost:4566

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=claims
DYNAMODB_ENDPOINT_URL=http://localhost:4566

# SNS Configuration
SNS_DEAD_LETTER_TOPIC_NAME=claims-dead-letter-topic
SNS_ENDPOINT_URL=http://localhost:4566

# Lambda Configuration
LAMBDA_ROLE_ARN=arn:aws:iam::000000000000:role/lambda-role
LAMBDA_ENDPOINT_URL=http://localhost:4566
LAMBDA_TIMEOUT=60
LAMBDA_MEMORY=256

# Minikube Configuration (for local Kubernetes)
MINIKUBE_PROFILE=minikube
KUBERNETES_NAMESPACE=default

# Application Configuration
LOG_LEVEL=INFO
DEBUG=false

# Producer Configuration
PRODUCER_MESSAGE_COUNT=1
PRODUCER_TEST_FRAUD=false

# Consumer Configuration
CONSUMER_AUTO_COMMIT=true
CONSUMER_SESSION_TIMEOUT=30000

# Reporting Configuration
REPORTING_MAX_EXECUTIONS=10
